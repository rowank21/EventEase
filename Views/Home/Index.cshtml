@{
    ViewData["Title"] = "Home";
}

<div class="text-center">
    <h1 class="display-4 fw-bold" style="background: linear-gradient(45deg, #4361ee, #4cc9f0); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        Welcome to EventEase
    </h1>
    <p class="lead text-muted">Your premier event management solution for seamless venue booking and event coordination</p>
</div>

<div class="row mt-5">
    <div class="col-md-4 mb-4">
        <div class="dashboard-card">
            <i class="fas fa-building"></i>
            <h3>Venues</h3>
            <p class="text-muted">Manage your venues with ease</p>
            <div class="number" id="venueCount">0</div>
            <a asp-controller="Venues" asp-action="Index" class="btn btn-primary mt-3">
                <i class="fas fa-arrow-right me-2"></i>View Venues
            </a>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="dashboard-card">
            <i class="fas fa-calendar"></i>
            <h3>Events</h3>
            <p class="text-muted">Create and manage events</p>
            <div class="number" id="eventCount">0</div>
            <a asp-controller="Events" asp-action="Index" class="btn btn-primary mt-3">
                <i class="fas fa-arrow-right me-2"></i>View Events
            </a>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="dashboard-card">
            <i class="fas fa-ticket-alt"></i>
            <h3>Bookings</h3>
            <p class="text-muted">Track all your bookings</p>
            <div class="number" id="bookingCount">0</div>
            <a asp-controller="Bookings" asp-action="Index" class="btn btn-primary mt-3">
                <i class="fas fa-arrow-right me-2"></i>View Bookings
            </a>
        </div>
    </div>
</div>

<div class="row mt-5">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-star me-2"></i>Why Choose EventEase?
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 text-center">
                        <i class="fas fa-shield-alt fa-3x" style="color: var(--primary-color);"></i>
                        <h5 class="mt-3">Secure Bookings</h5>
                        <p>Your data is always protected</p>
                    </div>
                    <div class="col-md-4 text-center">
                        <i class="fas fa-clock fa-3x" style="color: var(--primary-color);"></i>
                        <h5 class="mt-3">Real-time Availability</h5>
                        <p>Never double-book a venue again</p>
                    </div>
                    <div class="col-md-4 text-center">
                        <i class="fas fa-chart-line fa-3x" style="color: var(--primary-color);"></i>
                        <h5 class="mt-3">Easy Management</h5>
                        <p>Intuitive interface for specialists</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Animate counting numbers
            function animateNumber(element, target) {
                let current = 0;
                let increment = Math.ceil(target / 50);
                let timer = setInterval(function() {
                    current += increment;
                    if (current >= target) {
                        clearInterval(timer);
                        current = target;
                    }
                    $(element).text(current);
                }, 20);
            }

            // Get counts from API 
            $.get('/api/venues/count', function(data) { animateNumber('#venueCount', data); });
            $.get('/api/events/count', function(data) { animateNumber('#eventCount', data); });
            $.get('/api/bookings/count', function(data) { animateNumber('#bookingCount', data); });
        });
    </script>
}